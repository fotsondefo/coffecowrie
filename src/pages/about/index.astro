---
import CocoBaseLayout from '@/layouts/CocoBaseLayout.astro'
---

<CocoBaseLayout title="About" description="Learn about the history, mission, and team behind COFFEE&COWRIE." activeNav="about">
  <main class="w-full">

    <!-- ── Hero ── -->
    <section class="max-w-[1600px] mx-auto px-6 md:px-12 pt-24 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8 pr-0 lg:pr-12">
          <h1 class="font-display font-normal text-5xl md:text-6xl lg:text-7xl text-coco-green tracking-tight leading-tight reveal-text">
            Cultivating Knowledge<br>For Future Generations
          </h1>
          <div class="w-24 h-1 bg-coco-green/20"></div>
          <p class="font-serif text-2xl text-coco-green/80 leading-relaxed max-w-xl">
            We are dedicated to fostering an environment where innovation meets tradition, empowering minds to explore, discover, and lead in a rapidly evolving world.
          </p>
        </div>
        <div class="bg-coco-green/5 aspect-[4/3] rounded-lg border border-coco-green/10 flex items-center justify-center relative overflow-hidden group hover-trigger" data-cursor="VIEW">
          <i data-lucide="image" class="w-12 h-12 text-coco-green/20" stroke-width="1.5"></i>
        </div>
      </div>
    </section>

    <!-- ── Mission / Values ── -->
    <section class="w-full bg-coco-green/[0.03] py-24 md:py-32 border-y border-coco-green/10">
      <div class="max-w-[1600px] mx-auto px-6 md:px-12">
        <div class="max-w-4xl mx-auto text-center space-y-8 mb-24">
          <div class="inline-block px-6 py-3 bg-coco-green text-coco-ivory text-xs font-sans font-normal tracking-[0.15em] uppercase">
            Our Purpose
          </div>
          <p class="font-serif text-3xl md:text-4xl text-coco-green leading-relaxed">
            To bridge the gap between historical wisdom and modern advancement, creating a unique educational ecosystem that nurtures critical thinking and global consciousness.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-10 lg:p-12 border border-coco-green/10 shadow-sm hover:shadow-md transition-shadow hover-trigger" data-cursor="READ">
            <i data-lucide="target" class="w-8 h-8 text-coco-orange mb-8" stroke-width="1.5"></i>
            <h3 class="font-display font-normal text-2xl text-coco-green tracking-tight mb-4">Our Mission</h3>
            <div class="w-12 h-px bg-coco-green/20 mb-6"></div>
            <p class="font-sans font-light text-lg text-coco-green/70 leading-relaxed">
              Delivering exceptional education through innovative curriculum and hands-on research opportunities that challenge the status quo.
            </p>
          </div>
          <div class="bg-white p-10 lg:p-12 border border-coco-green/10 shadow-sm hover:shadow-md transition-shadow hover-trigger" data-cursor="READ">
            <i data-lucide="eye" class="w-8 h-8 text-coco-orange mb-8" stroke-width="1.5"></i>
            <h3 class="font-display font-normal text-2xl text-coco-green tracking-tight mb-4">Our Vision</h3>
            <div class="w-12 h-px bg-coco-green/20 mb-6"></div>
            <p class="font-sans font-light text-lg text-coco-green/70 leading-relaxed">
              To be the global benchmark for interdisciplinary studies, shaping leaders who drive transformative academic and social excellence.
            </p>
          </div>
          <div class="bg-white p-10 lg:p-12 border border-coco-green/10 shadow-sm hover:shadow-md transition-shadow hover-trigger" data-cursor="READ">
            <i data-lucide="heart" class="w-8 h-8 text-coco-orange mb-8" stroke-width="1.5"></i>
            <h3 class="font-display font-normal text-2xl text-coco-green tracking-tight mb-4">Our Values</h3>
            <div class="w-12 h-px bg-coco-green/20 mb-6"></div>
            <p class="font-sans font-light text-lg text-coco-green/70 leading-relaxed">
              Integrity, inclusivity, intellectual curiosity, and an unwavering commitment to sustainable progress for all communities.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Timeline ── -->
    <section class="w-full py-24 md:py-32 bg-coco-ivory">
      <div class="max-w-[1200px] mx-auto px-6 md:px-12">
        <div class="text-center mb-24 space-y-6">
          <div class="inline-block px-6 py-3 bg-coco-green/10 text-coco-green text-xs font-sans font-normal tracking-[0.15em] uppercase">
            Our History
          </div>
          <h2 class="font-display font-normal text-4xl md:text-5xl text-coco-green tracking-tight">A Legacy of Excellence</h2>
        </div>

        <div class="relative w-full">
          <div class="absolute left-1/2 top-0 bottom-0 w-px bg-coco-green/20 -translate-x-1/2 hidden md:block"></div>
          <div class="space-y-24">

            <div class="relative flex flex-col md:flex-row justify-between items-center md:items-start group">
              <div class="absolute left-0 md:left-1/2 top-2 md:top-3 w-3 h-3 bg-coco-orange rounded-full md:-translate-x-1/2 shadow-[0_0_0_6px_#F7F1E5]"></div>
              <div class="w-full md:w-[45%] pl-8 md:pl-0 md:pr-16 md:text-right hover-trigger" data-cursor="EXPLORE">
                <span class="font-sans font-light tracking-[0.15em] uppercase text-coco-orange text-sm mb-3 block">1985</span>
                <h3 class="font-display font-normal text-2xl text-coco-green tracking-tight mb-4">Foundation Established</h3>
                <p class="font-serif text-xl text-coco-green/70 leading-relaxed">
                  COFFEE&amp;COWRIE began as an independent research collective, focusing on the critical intersection of cultural history and modern sociological paradigms.
                </p>
              </div>
              <div class="hidden md:block md:w-[45%]"></div>
            </div>

            <div class="relative flex flex-col md:flex-row-reverse justify-between items-center md:items-start group">
              <div class="absolute left-0 md:left-1/2 top-2 md:top-3 w-3 h-3 bg-coco-green rounded-full md:-translate-x-1/2 shadow-[0_0_0_6px_#F7F1E5] transition-colors group-hover:bg-coco-orange"></div>
              <div class="w-full md:w-[45%] pl-8 md:pl-16 hover-trigger" data-cursor="EXPLORE">
                <span class="font-sans font-light tracking-[0.15em] uppercase text-coco-green/50 text-sm mb-3 block group-hover:text-coco-orange transition-colors">2002</span>
                <h3 class="font-display font-normal text-2xl text-coco-green tracking-tight mb-4">Campus Expansion</h3>
                <p class="font-serif text-xl text-coco-green/70 leading-relaxed">
                  Opening of the Quartier de l'Innovation campus, introducing state-of-the-art facilities and expanding our academic programs globally.
                </p>
              </div>
              <div class="hidden md:block md:w-[45%]"></div>
            </div>

            <div class="relative flex flex-col md:flex-row justify-between items-center md:items-start group">
              <div class="absolute left-0 md:left-1/2 top-2 md:top-3 w-3 h-3 bg-coco-green rounded-full md:-translate-x-1/2 shadow-[0_0_0_6px_#F7F1E5] transition-colors group-hover:bg-coco-orange"></div>
              <div class="w-full md:w-[45%] pl-8 md:pl-0 md:pr-16 md:text-right hover-trigger" data-cursor="EXPLORE">
                <span class="font-sans font-light tracking-[0.15em] uppercase text-coco-green/50 text-sm mb-3 block group-hover:text-coco-orange transition-colors">2025</span>
                <h3 class="font-display font-normal text-2xl text-coco-green tracking-tight mb-4">Digital Transformation</h3>
                <p class="font-serif text-xl text-coco-green/70 leading-relaxed">
                  Launch of the Global Digital Scholars program, breaking down geographical barriers and redefining accessible elite education for the modern era.
                </p>
              </div>
              <div class="hidden md:block md:w-[45%]"></div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ── Team ── -->
    <section class="w-full bg-coco-green/[0.03] py-24 md:py-32 border-t border-coco-green/10">
      <div class="max-w-[1600px] mx-auto px-6 md:px-12">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8">
          <div class="space-y-6">
            <div class="inline-block px-6 py-3 bg-coco-green text-coco-ivory text-xs font-sans font-normal tracking-[0.15em] uppercase">
              Leadership
            </div>
            <h2 class="font-display font-normal text-4xl md:text-5xl text-coco-green tracking-tight">Our Faculty &amp; Board</h2>
          </div>
          <button class="border border-coco-green/20 px-10 py-4 text-xs font-sans font-normal tracking-[0.15em] uppercase text-coco-green hover:bg-coco-green hover:text-coco-ivory transition-colors hover-trigger" data-cursor="ALL">
            View All Members
          </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {[
            { name: 'Dr. Elena Rostova', role: 'Dean of Faculty' },
            { name: 'Marcus Chen', role: 'Director of Research' },
            { name: 'Sarah Al-Fayed', role: 'Head of Innovation' },
            { name: 'James Arrington', role: 'Lead Sociologist' },
          ].map(member => (
            <div class="group cursor-pointer hover-trigger" data-cursor="PROFILE">
              <div class="bg-coco-green/5 aspect-[4/5] mb-6 flex items-center justify-center border border-coco-green/5 overflow-hidden">
                <i data-lucide="user" class="w-12 h-12 text-coco-green/20 group-hover:scale-110 transition-transform duration-700" stroke-width="1.5"></i>
              </div>
              <h3 class="font-display font-normal text-2xl text-coco-green tracking-tight mb-2">{member.name}</h3>
              <p class="font-sans font-light text-sm text-coco-orange uppercase tracking-[0.1em]">{member.role}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
</CocoBaseLayout>
