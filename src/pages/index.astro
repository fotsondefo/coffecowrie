<script slot="scripts" is:inline>
  // ── Horizontal Scroll ──
  const track   = document.getElementById('h-track');
  const section = document.querySelector('.horizontal-section');
  window.addEventListener('scroll', () => {
    if (!section || !track) return;
    const offsetTop     = section.offsetTop;
    const sectionHeight = section.offsetHeight;
    const scrollY       = window.scrollY;
    const winH          = window.innerHeight;
    if (scrollY >= offsetTop && scrollY <= offsetTop + sectionHeight - winH) {
      const pct        = (scrollY - offsetTop) / (sectionHeight - winH);
      const moveAmount = track.scrollWidth - window.innerWidth;
      track.style.transform = `translateX(-${pct * moveAmount}px)`;
    }
  });

  // ── Loading Curtain ──
  window.addEventListener('load', () => {
    const loader  = document.getElementById('loader');
    const logo    = document.getElementById('loader-logo');
    const text    = document.getElementById('loader-text');
    const tagline = document.getElementById('loader-tagline');
    if (!loader) return;

    // Step 1 — reveal logo
    if (logo) {
      logo.style.opacity   = '1';
      logo.style.transform = 'translateY(0)';
    }

    // Step 2 — slide up brand name
    setTimeout(() => {
      if (text) text.style.transform = 'translateY(0)';
    }, 250);

    // Step 3 — slide up tagline
    setTimeout(() => {
      if (tagline) tagline.style.transform = 'translateY(0)';
    }, 420);

    // Step 4 — lift curtain
    setTimeout(() => {
      loader.style.transform = 'translateY(-100%)';

      // Trigger hero title reveal after curtain lifts
      const heroTitle = document.querySelector('#hero-title');
      if (heroTitle) {
        heroTitle.classList.add('active');
        heroTitle.querySelectorAll('.char').forEach((char, i) => {
          setTimeout(() => {
            char.style.transform = 'translateY(0)';
            char.style.opacity   = '1';
          }, 800 + i * 50);
        });
      }
    }, 2200);
  });
</script>
