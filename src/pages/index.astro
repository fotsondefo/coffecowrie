---
import { getCollection } from 'astro:content'
import CocoBaseLayout from '@/layouts/CocoBaseLayout.astro'

const allArticles = await getCollection('journal', ({ data }) => !data.draft)
const recentArticles = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)
---

<CocoBaseLayout title="The Future of Leadership">

  <!-- ── Loading Curtain ── -->
  <div slot="loader" id="loader" class="fixed inset-0 z-[100] flex flex-col items-center justify-center" style="background-color:#1a244f; transform:translateY(0); transition:transform 1s cubic-bezier(0.87,0,0.13,1);">

    <!-- Pigeon / Brand mark -->
    <div id="loader-logo" style="opacity:0; transform:translateY(24px); transition:opacity 0.7s ease, transform 0.7s ease;">
      <img
        src="/images/pigeon.png"
        alt="Coffee &amp; Cowrie — pigeon logo"
        width="160"
        height="200"
        style="width:160px; height:auto; object-fit:contain;"
      />
    </div>

    <!-- Brand name -->
    <div class="overflow-hidden mt-6">
      <div id="loader-text" style="transform:translateY(100%); transition:transform 0.7s cubic-bezier(0.16,1,0.3,1);">
        <p class="font-display text-white text-5xl md:text-7xl leading-none text-center" style="font-family:'Gilroy',ui-sans-serif,sans-serif; font-weight:800; letter-spacing:-0.03em; text-transform:uppercase;">
          COFFEE<span style="font-size:0.52em; color:#cf8429; vertical-align:middle; margin:0 0.15em; font-weight:800;">&amp;</span>COWRIE
        </p>
      </div>
    </div>

    <!-- Tagline -->
    <div class="overflow-hidden mt-3">
      <p id="loader-tagline" class="text-white/60 text-xs tracking-[0.35em] uppercase text-center" style="font-family:'Gilroy',ui-sans-serif,sans-serif; font-weight:300; transform:translateY(100%); transition:transform 0.6s cubic-bezier(0.16,1,0.3,1) 0.15s;">
        TOGETHER FOR AFRICA
      </p>
    </div>

  </div>

  <main class="w-full">

    <!-- ── 1. HERO ── -->
    <section class="relative h-screen w-full overflow-hidden flex flex-col justify-end pb-12 md:pb-24 px-6 md:px-20" id="hero">
      <!-- Background -->
      <div class="absolute inset-0 z-0">
        <img
          src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg"
          class="w-full h-full object-cover hero-image brightness-75"
          alt="Future Leaders"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-coco-green/30 via-transparent to-coco-green/90 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-coco-green via-coco-green/40 to-transparent opacity-90"></div>
        <div class="absolute inset-0 bg-noise opacity-20 mix-blend-overlay"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 w-full max-w-[1800px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
        <!-- Title -->
        <div class="lg:col-span-8">
          <div class="overflow-hidden mb-4">
            <span class="inline-block text-coco-lime text-xs font-normal tracking-[0.2em] uppercase border border-coco-lime/30 rounded-full px-3 py-1 backdrop-blur-md opacity-0 animate-[fadeIn_1s_ease_1s_forwards]">Est. 2025</span>
          </div>
          <h1 class="font-display font-normal text-[11vw] leading-[0.85] tracking-tighter text-coco-ivory reveal-text mix-blend-overlay opacity-90" id="hero-title">
            GATHER <br>
            <span class="text-white opacity-100">THE ELITE</span>
          </h1>
        </div>

        <!-- Description & Stats -->
        <div class="lg:col-span-4 mb-2">
          <p class="font-serif text-2xl text-coco-ivory/80 leading-relaxed mb-8 border-l border-coco-orange/50 pl-6">
            Where the real value of the African diaspora is forged. We shape our circle for the minds that will rewrite history's next chapters.
          </p>
          <div class="grid grid-cols-2 gap-8 border-t border-white/10 pt-8 opacity-0 animate-[fadeIn_1s_ease_1.5s_forwards]">
            <div>
              <span class="block text-3xl font-display text-coco-ivory">50</span>
              <span class="text-xs uppercase tracking-widest text-coco-lime/70">Annual Intakes</span>
            </div>
            <div>
              <span class="block text-3xl font-display text-coco-ivory">01</span>
              <span class="text-xs uppercase tracking-widest text-coco-lime/70">Global Vision</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="absolute bottom-0 left-0 w-full px-6 md:px-20 py-8 border-t border-white/10 flex justify-between items-center text-xs uppercase tracking-widest text-coco-ivory/50">
        <div class="flex items-center gap-4">
          <div class="w-2 h-2 rounded-full bg-coco-orange animate-pulse"></div>
          <span>Applications Open</span>
        </div>
        <div class="hidden md:block">Scroll to Explore</div>
      </div>
    </section>

    <!-- ── 2. MARQUEE SEPARATOR ── -->
    <div class="py-6 bg-coco-green text-coco-ivory overflow-hidden border-y border-white/5 relative z-20">
      <div class="marquee-container">
        <div class="marquee-content font-display text-4xl md:text-6xl font-normal tracking-tighter opacity-80">
          <span>LEADERSHIP &amp; MENTORSHIP</span>
          <span class="font-serif italic text-coco-lime font-light">StartUps</span>
          <span>COMMUNITY IMPACT</span>
          <span class="font-serif italic text-coco-lime font-light">Networking</span>
          <span>EXCELLENCE</span>
          <span class="font-serif italic text-coco-lime font-light">Advisory</span>
        </div>
        <div class="marquee-content font-display text-4xl md:text-6xl font-normal tracking-tighter opacity-80" aria-hidden="true">
          <span>LEADERSHIP &amp; MENTORSHIP</span>
          <span class="font-serif italic text-coco-lime font-light">Excellence</span>
          <span>CHARACTER</span>
          <span class="font-serif italic text-coco-lime font-light">Governance</span>
          <span>POWER</span>
          <span class="font-serif italic text-coco-lime font-light">Legacy</span>
        </div>
      </div>
    </div>

    <!-- ── 3. PHILOSOPHY ── -->
    <section id="sanctuary" class="relative py-32 px-6 md:px-20 max-w-[1800px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-20 bg-coco-ivory">
      <!-- Left sticky -->
      <div class="lg:col-span-5 relative">
        <div class="sticky top-32 space-y-12">
          <div>
            <span class="inline-block px-3 py-1 border border-coco-green/20 rounded-full text-xs uppercase tracking-widest mb-6 text-coco-green">The Vision</span>
            <h2 class="font-display font-normal text-4xl md:text-5xl lg:text-6xl text-coco-green tracking-tighter leading-[1.05] reveal-text">
              BEYOND <br>
              <span class="font-serif italic text-coco-orange font-light">CONNECTING</span>.
            </h2>
          </div>
          <p class="font-sans font-light text-lg text-coco-green/80 leading-relaxed">
            We operate at the intersection of talent and opportunity — building the bridges that transform exceptional individuals into consequential leaders.
          </p>
          <div class="space-y-6 pt-8 border-t border-coco-green/10">
            <div class="group cursor-pointer hover-trigger" data-cursor="VIEW">
              <h3 class="font-display text-lg font-normal flex items-center justify-between text-coco-green">
                <span>01. SYNERGY</span>
                <i data-lucide="arrow-right" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity text-coco-orange" stroke-width="1.5"></i>
              </h3>
              <p class="text-sm mt-2 opacity-60 max-w-sm font-sans">Bringing together the skills of the diaspora.</p>
            </div>
            <div class="group cursor-pointer hover-trigger" data-cursor="VIEW">
              <h3 class="font-display text-lg font-normal flex items-center justify-between text-coco-green">
                <span>02. BOOSTER</span>
                <i data-lucide="arrow-right" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity text-coco-orange" stroke-width="1.5"></i>
              </h3>
              <p class="text-sm mt-2 opacity-60 max-w-sm font-sans">Becoming the Strategic Bridge to Leadership.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right images -->
      <div class="lg:col-span-7 space-y-24 pt-20">
        <div class="relative aspect-[4/5] md:aspect-[16/10] w-full ml-auto mask-reveal group">
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1200&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" alt="Environment">
          <div class="absolute inset-0 bg-gradient-to-tr from-coco-green/20 to-transparent mix-blend-multiply"></div>
          <div class="absolute -bottom-6 -left-6 bg-coco-ivory p-6 border border-coco-green/10 shadow-2xl max-w-[240px]">
            <p class="font-display text-xs font-semibold uppercase tracking-widest text-coco-orange">Environment</p>
            <p class="font-serif text-sm italic mt-2 text-coco-green">Designed to elevate thought.</p>
          </div>
        </div>
        <div class="relative aspect-[3/4] w-full md:w-3/5 mr-auto mask-reveal group">
          <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?q=80&w=1200&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" alt="Discussion">
        </div>
      </div>
    </section>

    <!-- ── 4. OFFERS (Horizontal Scroll) ── -->
    <section id="facilities" class="horizontal-section bg-coco-green text-coco-ivory">
      <div class="horizontal-wrapper">
        <div class="absolute top-12 left-6 md:left-20 z-10">
          <span class="text-xs uppercase tracking-[0.3em] opacity-60">Our Offers</span>
          <h2 class="font-display text-4xl md:text-5xl font-normal mt-2 tracking-tight">SEE WHAT WE DO</h2>
        </div>

        <div class="cards-track" id="h-track">
          <!-- Intro text -->
          <div class="flex-shrink-0 w-[80vw] md:w-[30vw] h-[60vh] flex flex-col justify-center pr-20">
            <p class="font-serif text-3xl md:text-4xl leading-tight">
              "Our ecosystem shapes leaders. Every detail at COFFEE&amp;COWRIE is engineered for focus."
            </p>
            <div class="w-16 h-px bg-coco-orange mt-8"></div>
          </div>

          <!-- Card 1 -->
          <div class="flex-shrink-0 relative w-[85vw] md:w-[45vw] h-[70vh] group overflow-hidden border border-white/10 hover-trigger" data-cursor="EXPLORE">
            <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/4734259a-bad7-422f-981e-ce01e79184f2_1600w.jpg" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-60 group-hover:opacity-100" alt="Events">
            <div class="absolute inset-0 bg-gradient-to-t from-coco-green via-transparent to-transparent opacity-90"></div>
            <div class="absolute bottom-0 left-0 p-10 transform transition-transform duration-500 group-hover:-translate-y-2">
              <span class="font-mono text-coco-orange text-xs mb-3 block">01</span>
              <h3 class="font-display text-4xl md:text-5xl font-normal tracking-tight mb-4">EVENTS</h3>
              <p class="opacity-0 group-hover:opacity-70 transition-opacity duration-500 text-sm max-w-sm leading-relaxed translate-y-4 group-hover:translate-y-0 font-sans">
                Curated gatherings where the diaspora's brightest minds converge, collaborate, and build lasting strategic relationships.
              </p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="flex-shrink-0 relative w-[85vw] md:w-[45vw] h-[70vh] group overflow-hidden border border-white/10 hover-trigger" data-cursor="FOCUS">
            <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/c543a9e1-f226-4ced-80b0-feb8445a75b9_1600w.jpg" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-60 group-hover:opacity-100" alt="Podcast">
            <div class="absolute inset-0 bg-gradient-to-t from-coco-green via-transparent to-transparent opacity-90"></div>
            <div class="absolute bottom-0 left-0 p-10 transform transition-transform duration-500 group-hover:-translate-y-2">
              <span class="font-mono text-coco-orange text-xs mb-3 block">02</span>
              <h3 class="font-display text-4xl md:text-5xl font-normal tracking-tight mb-4">PODCAST</h3>
              <p class="opacity-0 group-hover:opacity-70 transition-opacity duration-500 text-sm max-w-sm leading-relaxed translate-y-4 group-hover:translate-y-0 font-sans">
                Long-form conversations with the leaders, thinkers, and builders shaping the next decade of African excellence.
              </p>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="flex-shrink-0 relative w-[85vw] md:w-[45vw] h-[70vh] group overflow-hidden border border-white/10 hover-trigger" data-cursor="RECHARGE">
            <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/5bab247f-35d9-400d-a82b-fd87cfe913d2_1600w.webp" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-60 group-hover:opacity-100" alt="Business Incubator">
            <div class="absolute inset-0 bg-gradient-to-t from-coco-green via-transparent to-transparent opacity-90"></div>
            <div class="absolute bottom-0 left-0 p-10 transform transition-transform duration-500 group-hover:-translate-y-2">
              <span class="font-mono text-coco-orange text-xs mb-3 block">03</span>
              <h3 class="font-display text-4xl md:text-5xl font-normal tracking-tight mb-4">BUSINESS<br>INCUBATOR</h3>
              <p class="opacity-0 group-hover:opacity-70 transition-opacity duration-500 text-sm max-w-sm leading-relaxed translate-y-4 group-hover:translate-y-0 font-sans">
                Structured support for members building ventures at the intersection of technology, governance, and social impact.
              </p>
            </div>
          </div>

          <div class="flex-shrink-0 w-[20vw]"></div>
        </div>
      </div>
    </section>

    <!-- ── 5. MENTORS ── -->
    <section id="team" class="py-32 px-6 md:px-20 max-w-[1800px] mx-auto bg-coco-ivory">
      <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
        <div>
          <span class="text-xs font-semibold tracking-widest uppercase text-coco-orange mb-4 block">The Faculty</span>
          <h2 class="font-display text-4xl md:text-6xl text-coco-green tracking-tighter reveal-text">ELITE MENTORS</h2>
        </div>
        <p class="font-serif text-xl max-w-md text-coco-green/70 text-right">
          Learn from former heads of state, industry titans, and strategic masterminds.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group relative aspect-[3/4] overflow-hidden hover-trigger" data-cursor="PROFILE">
          <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 filter grayscale group-hover:grayscale-0" alt="James Ellis">
          <div class="absolute inset-0 bg-gradient-to-t from-coco-green to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
            <h3 class="font-display text-2xl text-coco-ivory">JAMES ELLIS</h3>
            <p class="text-coco-orange text-xs tracking-widest uppercase mt-1">Economics &amp; Strategy</p>
          </div>
        </div>
        <div class="group relative aspect-[3/4] overflow-hidden hover-trigger" data-cursor="PROFILE">
          <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 filter grayscale group-hover:grayscale-0" alt="Elena Rosta">
          <div class="absolute inset-0 bg-gradient-to-t from-coco-green to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
            <h3 class="font-display text-2xl text-coco-ivory">ELENA ROSTA</h3>
            <p class="text-coco-orange text-xs tracking-widest uppercase mt-1">International Relations</p>
          </div>
        </div>
        <div class="group relative aspect-[3/4] overflow-hidden hover-trigger" data-cursor="PROFILE">
          <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 filter grayscale group-hover:grayscale-0" alt="David Chen">
          <div class="absolute inset-0 bg-gradient-to-t from-coco-green to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
            <h3 class="font-display text-2xl text-coco-ivory">DAVID CHEN</h3>
            <p class="text-coco-orange text-xs tracking-widest uppercase mt-1">Technological Governance</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 6. CANDIDACY ── -->
    <section id="membership" class="py-32 px-6 md:px-20 max-w-[1800px] mx-auto bg-white border-t border-coco-green/5">
      <div class="text-center mb-24">
        <h2 class="font-display text-4xl md:text-6xl text-coco-green tracking-tighter mb-4 reveal-text">CANDIDACY</h2>
        <div class="w-px h-12 bg-coco-orange mx-auto mb-4"></div>
        <p class="font-serif text-xl italic text-coco-green/60">Strictly by invitation or referral.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="relative group p-10 border border-coco-green/10 bg-coco-ivory hover:bg-coco-green transition-colors duration-500 overflow-hidden hover-trigger" data-cursor="APPLY">
          <div class="absolute top-0 right-0 w-24 h-24 bg-coco-orange/10 rounded-bl-full group-hover:bg-coco-orange transition-colors"></div>
          <h3 class="font-display text-2xl text-coco-green group-hover:text-coco-ivory mb-2">FELLOW</h3>
          <p class="text-xs tracking-widest uppercase text-coco-orange mb-8">Under 45</p>
          <ul class="space-y-4 text-sm text-coco-green/70 group-hover:text-coco-ivory/80 transition-colors font-sans">
            <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-coco-orange flex-shrink-0"></div>Full access to mentorship network</li>
            <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-coco-orange flex-shrink-0"></div>Priority event invitations</li>
          </ul>
        </div>
        <div class="relative group p-10 border border-coco-green/20 bg-coco-black text-coco-ivory overflow-hidden scale-105 shadow-2xl z-10 hover-trigger" data-cursor="PRESTIGE">
          <div class="absolute inset-0 bg-noise opacity-20"></div>
          <div class="absolute top-0 right-0 bg-coco-orange text-xs font-semibold px-3 py-1 uppercase">Select</div>
          <h3 class="font-display text-2xl mb-2">RESIDENT</h3>
          <p class="text-xs tracking-widest uppercase text-coco-orange mb-8">Full Membership</p>
          <ul class="space-y-4 text-sm opacity-80 font-sans">
            <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-coco-orange flex-shrink-0"></div>Exclusive leadership programs</li>
            <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-coco-orange flex-shrink-0"></div>Incubator access</li>
            <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-coco-orange flex-shrink-0"></div>Board advisory eligibility</li>
          </ul>
        </div>
        <div class="relative group p-10 border border-coco-green/10 bg-coco-ivory hover:bg-coco-green transition-colors duration-500 overflow-hidden hover-trigger" data-cursor="APPLY">
          <div class="absolute top-0 right-0 w-24 h-24 bg-coco-orange/10 rounded-bl-full group-hover:bg-coco-orange transition-colors"></div>
          <h3 class="font-display text-2xl text-coco-green group-hover:text-coco-ivory mb-2">PARTNER</h3>
          <p class="text-xs tracking-widest uppercase text-coco-orange mb-8">Organization</p>
          <ul class="space-y-4 text-sm text-coco-green/70 group-hover:text-coco-ivory/80 transition-colors font-sans">
            <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-coco-orange flex-shrink-0"></div>Institutional collaboration</li>
            <li class="flex items-center gap-3"><div class="w-1.5 h-1.5 rounded-full bg-coco-orange flex-shrink-0"></div>Co-branded research</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ── 7. JOURNAL PREVIEW ── -->
    <section id="journal-preview" class="py-32 px-6 md:px-20 max-w-[1800px] mx-auto border-t border-coco-green/10 bg-coco-ivory">
      <div class="flex items-center justify-between mb-16">
        <h2 class="font-display text-4xl md:text-5xl text-coco-green tracking-tighter reveal-text">THE JOURNAL</h2>
        <a href="/journal" class="hidden md:flex items-center gap-2 text-xs font-semibold tracking-widest uppercase text-coco-orange hover:text-coco-green transition-colors group">
          View Archive
          <i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" stroke-width="1.5"></i>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {recentArticles.map(article => (
          <article class="group cursor-pointer hover-trigger" data-cursor="READ">
            <div class="aspect-[16/10] overflow-hidden mb-6 relative bg-coco-green/5">
              {article.data.heroImage ? (
                <img src={article.data.heroImage.src} alt={article.data.heroImage.alt || article.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              ) : (
                <div class="w-full h-full bg-coco-green/10 flex items-center justify-center">
                  <i data-lucide="file-text" class="w-8 h-8 text-coco-green/20" stroke-width="1.5"></i>
                </div>
              )}
              <div class="absolute inset-0 bg-coco-green/20 mix-blend-multiply z-10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="flex items-center gap-4 mb-3 text-xs uppercase tracking-widest text-coco-green/60">
              <span>{article.data.category}</span>
              <span class="w-1 h-1 bg-coco-orange rounded-full"></span>
              <span>{article.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
            <a href={`/journal/${article.id}`}>
              <h3 class="font-display text-xl text-coco-green leading-tight group-hover:text-coco-orange transition-colors">{article.data.title}</h3>
            </a>
          </article>
        ))}
      </div>
    </section>

    <!-- ── 8. PARTNERS ── -->
    <section id="partners" class="py-20 px-6 md:px-20 bg-coco-ivory border-y border-coco-green/5">
      <div class="max-w-[1800px] mx-auto">
        <div class="flex flex-col items-center mb-12">
