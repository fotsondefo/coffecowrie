---
import CocoBaseLayout from '@/layouts/CocoBaseLayout.astro'

const faqItems = [
  {
    q: 'How do I apply for the leadership fellowship?',
    a: 'Applications for our fellowship program open biannually. Candidates must submit a detailed portfolio of their governance experience, along with a proposal for a technological intervention in their local political structure.'
  },
  {
    q: 'Where is the institute located?',
    a: 'Our primary headquarters is in Québec City, Canada. However, we operate globally through a decentralized network of researchers and policy nodes in Geneva, Nairobi, and Singapore.'
  },
  {
    q: 'Press & Media Inquiries',
    a: 'For press and media engagements, please direct your correspondence to media@coffeecowrie.edu. Our communications team typically responds within 24 hours.'
  },
  {
    q: 'Partnership Opportunities',
    a: 'We collaborate with state governments, NGOs, and select technological enterprises. Submit an executive summary of your proposed partnership via our institutional portal.'
  },
]
---

<CocoBaseLayout title="Contact" description="Get in touch with the COFFEE&COWRIE institute." activeNav="contact">
  <main class="w-full">

    <!-- ── Hero Title Block ── -->
    <section class="w-full px-6 md:px-12 pt-16 pb-12">
      <div class="w-full max-w-[1600px] mx-auto bg-coco-green py-24 md:py-32 px-8 md:px-20 hover-trigger" data-cursor="SCROLL">
        <h1 class="font-display font-normal text-5xl md:text-7xl lg:text-8xl text-coco-ivory tracking-tight reveal-text">
          CONTACT
        </h1>
      </div>
    </section>

    <!-- ── Main Content ── -->
    <section class="max-w-[1600px] mx-auto px-6 md:px-12 pb-32">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-32">

        <!-- Left: FAQ Accordion -->
        <div class="lg:col-span-7 space-y-0">
          {faqItems.map((item, i) => (
            <div class="accordion-item border-b border-coco-green/10 group">
              <button
                class="w-full py-8 flex items-center gap-6 text-left outline-none hover-trigger"
                data-cursor="VIEW"
                data-accordion-btn
              >
                <div class="w-3 h-3 bg-coco-green/10 group-hover:bg-coco-orange transition-colors relative flex-shrink-0">
                  <div class="absolute inset-0 m-auto w-full h-px bg-coco-ivory transition-transform duration-300"></div>
                  <div class="absolute inset-0 m-auto w-px h-full bg-coco-ivory transition-transform duration-300 vertical-line"></div>
                </div>
                <span class="font-sans text-xl md:text-2xl font-normal text-coco-green tracking-tight group-hover:text-coco-orange transition-colors">{item.q}</span>
              </button>
              <div class="overflow-hidden transition-all duration-500 ease-out-expo accordion-content" style="height: 0px">
                <div class="pb-8 pl-9 font-serif text-xl text-coco-green/70 leading-relaxed font-light">
                  {item.a}
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Right: Contact Details -->
        <div class="lg:col-span-5">
          <div class="border-t border-coco-green/20 pt-8">
            <div class="font-sans text-lg leading-relaxed text-coco-green/80 space-y-8 mb-16">
              <div>
                <p class="font-medium text-coco-green mb-1 tracking-tight">Global Headquarters</p>
                <p class="font-light">12 Heritage Lane,<br>Québec City, QC G1R 4P5<br>Canada</p>
              </div>
              <div>
                <p class="font-medium text-coco-green mb-1 tracking-tight">Office Hours</p>
                <p class="font-light">Monday – Friday<br>9:00 AM – 5:00 PM EST</p>
              </div>
              <div>
                <p class="font-medium text-coco-green mb-1 tracking-tight">Direct Lines</p>
                <p class="font-light">
                  <a href="mailto:enquiries@coffeecowrie.edu" class="hover:text-coco-orange transition-colors inline-flex items-center gap-2">
                    <i data-lucide="mail" class="w-4 h-4" stroke-width="1.5"></i> enquiries@coffeecowrie.edu
                  </a><br>
                  <a href="tel:+15145550199" class="hover:text-coco-orange transition-colors inline-flex items-center gap-2 mt-2">
                    <i data-lucide="phone" class="w-4 h-4" stroke-width="1.5"></i> +1 514 555 0199
                  </a>
                </p>
              </div>
            </div>

            <!-- Quick email form -->
            <form class="bg-coco-green/5 p-2 flex items-center border border-coco-green/10 focus-within:border-coco-orange transition-colors hover-trigger" data-cursor="TYPE">
              <input type="email" placeholder="Email address" class="w-full bg-transparent px-4 py-3 outline-none font-sans text-base text-coco-green placeholder:text-coco-green/40">
              <button type="button" class="w-12 h-12 bg-coco-green/10 hover:bg-coco-orange transition-colors flex items-center justify-center flex-shrink-0 text-coco-green hover:text-white group">
                <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" stroke-width="1.5"></i>
              </button>
            </form>

          </div>
        </div>

      </div>
    </section>

    <!-- ── CTA Bar ── -->
    <section class="bg-coco-green py-6 px-6 md:px-12 relative overflow-hidden text-coco-ivory border-y border-coco-green/20">
      <div class="max-w-[1800px] mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-6 relative z-10">
        <h2 class="font-display font-medium text-2xl md:text-3xl tracking-tight reveal-text">STAY INFORMED ON GOVERNANCE</h2>
        <button class="bg-coco-ivory text-coco-green px-8 py-4 uppercase text-xs tracking-widest font-medium hover:bg-coco-orange hover:text-white transition-colors whitespace-nowrap hover-trigger" data-cursor="JOIN">
          Subscribe
        </button>
      </div>
    </section>

  </main>
</CocoBaseLayout>

<script slot="scripts" is:inline>
  // ── Accordion Logic ──
  document.querySelectorAll('.accordion-item button').forEach(button => {
    button.addEventListener('click', () => {
      const item    = button.parentElement;
      const content = item.querySelector('.accordion-content');
      const vLine   = item.querySelector('.vertical-line');
      const isOpen  = item.classList.contains('is-open');

      document.querySelectorAll('.accordion-item').forEach(other => {
        if (other !== item) {
          other.classList.remove('is-open');
          other.querySelector('.accordion-content').style.height = '0px';
          const otherLine = other.querySelector('.vertical-line');
          if (otherLine) otherLine.style.transform = 'scaleY(1)';
        }
      });

      if (isOpen) {
        item.classList.remove('is-open');
        content.style.height = '0px';
        if (vLine) vLine.style.transform = 'scaleY(1)';
      } else {
        item.classList.add('is-open');
        content.style.height = content.scrollHeight + 'px';
        if (vLine) vLine.style.transform = 'scaleY(0)';
      }
    });
  });
</script>
