---
interface Props {
  title: string
  description?: string
  activeNav?: string
  darkScrollbar?: boolean
}

const {
  title,
  description = 'COFFEE&COWRIE — Excellence in Leadership & Innovation',
  activeNav = '',
} = Astro.props

const navLeft = [
  { href: '/about', label: 'About', key: 'about' },
  { href: '#', label: 'Programs', key: 'programs' },
  { href: '#', label: 'Faculty', key: 'faculty' },
  { href: '#', label: 'Research', key: 'research' },
]

const navRight = [
  { href: '/journal', label: 'Journal', key: 'journal' },
  { href: '/contact', label: 'Contact', key: 'contact' },
]
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | COFFEE&COWRIE</title>
  <meta name="description" content={description}>

  <!-- Fonts -->
  <!-- Gilroy — police officielle Coffee & Cowrie (charte graphique) -->
  <!-- Free weights (Light 300 + ExtraBold 800) via CDN.                -->
  <!-- Pour la gamme complète, remplacer par les fichiers du dossier livré dans public/fonts/gilroy/ -->
  <link rel="preconnect" href="https://fonts.cdnfonts.com" crossorigin="">
  <link href="https://fonts.cdnfonts.com/css/gilroy-free" rel="stylesheet">

  <!-- Tailwind Play CDN -->
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <!-- Lucide Icons -->
  <script is:inline src="https://unpkg.com/lucide@latest"></script>

  <!-- Tailwind config with coco design tokens -->
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            coco: {
              green: '#1a244f',
              ivory: '#F7F1E5',
              lime: '#fff449',
              orange: '#cf8429',
              black: '#0a0a0a',
            }
          },
          fontFamily: {
            // Gilroy — police unique définie par la charte graphique Coffee & Cowrie
            sans:    ['Gilroy', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            display: ['Gilroy', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            serif:   ['Gilroy', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          },
          transitionTimingFunction: {
            'out-expo': 'cubic-bezier(0.19, 1, 0.22, 1)',
            'slow-mo': 'cubic-bezier(0.7, 0, 0.3, 1)',
          },
          backgroundImage: {
            'noise': "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E\")",
          }
        }
      }
    }
  </script>

  <style is:global>
    body {
      background-color: #F7F1E5;
      color: #1a244f;
      cursor: none;
      overflow-x: hidden;
      font-family: 'Gilroy', ui-sans-serif, system-ui, sans-serif;
      font-weight: 400;
    }

    /* ── Custom Cursor ── */
    .cursor-dot,
    .cursor-outline {
      position: fixed;
      top: 0;
      left: 0;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      z-index: 9999;
      pointer-events: none;
    }
    .cursor-dot {
      width: 6px;
      height: 6px;
      background-color: #cf8429;
    }
    .cursor-outline {
      width: 40px;
      height: 40px;
      border: 1px solid rgba(26, 36, 79, 0.3);
      transition: width 0.2s, height 0.2s, background-color 0.2s, border-color 0.2s;
    }
    body.hovering .cursor-outline {
      width: 60px;
      height: 60px;
      background-color: rgba(207, 132, 41, 0.1);
      border-color: #cf8429;
      mix-blend-mode: difference;
    }

    /* ── Text Reveal Animation ── */
    .char {
      display: inline-block;
      opacity: 0;
      transform: translateY(100%);
      transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1), opacity 1s ease;
    }
    .reveal-text.active .char {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Nav Underline ── */
    .nav-link::after {
      content: '';
      position: absolute;
      width: 0;
      height: 1px;
      bottom: -4px;
      left: 0;
      background-color: #cf8429;
      transition: width 0.3s ease;
    }
    .nav-link:hover::after { width: 100%; }

    /* ── Marquee ── */
    .marquee-container {
      display: flex;
      overflow: hidden;
      user-select: none;
      gap: 2rem;
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }
    .marquee-content {
      flex-shrink: 0;
      display: flex;
      justify-content: space-around;
      min-width: 100%;
      gap: 2rem;
      animation: marquee-scroll 30s linear infinite;
    }
    @keyframes marquee-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(calc(-100% - 2rem)); }
    }

    /* ── Image Mask Reveal ── */
    .mask-reveal {
      clip-path: inset(0 0 100% 0);
      transition: clip-path 1.5s cubic-bezier(0.7, 0, 0.2, 1);
    }
    .mask-reveal.active { clip-path: inset(0 0 0 0); }

    /* ── Horizontal Scroll ── */
    .horizontal-section { position: relative; height: 400vh; }
    .horizontal-wrapper {
      position: sticky; top: 0; height: 100vh;
      overflow: hidden; display: flex; align-items: center;
    }
    .cards-track { display: flex; gap: 4vw; padding-left: 10vw; }

    /* ── Vertical Tabs (home sidebar) ── */
    .vertical-tab {
      writing-mode: vertical-rl;
      text-orientation: mixed;
      transform: rotate(180deg);
    }

    /* ── Hero Image zoom ── */
    .hero-image { animation: scale-in 10s ease-out forwards; }
    @keyframes scale-in {
      0%   { transform: scale(1.1); }
      100% { transform: scale(1); }
    }

    /* ── Fade In ── */
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #F7F1E5; }
    ::-webkit-scrollbar-thumb { background: #1a244f; }

    /* ── Coco Prose (journal articles) — Gilroy per charte graphique ── */
    .coco-prose p {
      font-family: 'Gilroy', ui-sans-serif, sans-serif;
      font-size: 1.125rem;
      line-height: 1.85;
      color: rgba(26, 36, 79, 0.8);
      font-weight: 300;
      margin-bottom: 2.5rem;
    }
    .coco-prose h2 {
      font-family: 'Gilroy', ui-sans-serif, sans-serif;
      font-size: 1.75rem;
      font-weight: 800;
      color: #1a244f;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
    }
    .coco-prose h3 {
      font-family: 'Gilroy', ui-sans-serif, sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: #1a244f;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }
    .coco-prose blockquote {
      border-left: 2px solid #cf8429;
      padding-left: 1.5rem;
      margin: 2rem 0;
      font-style: italic;
      font-weight: 300;
      color: rgba(26, 36, 79, 0.7);
    }
  </style>
</head>

<body class="antialiased selection:bg-coco-orange selection:text-white">

  <!-- Custom Cursor -->
  <div class="cursor-dot hidden md:block"></div>
  <div class="cursor-outline hidden md:block"></div>

  <!-- Optional loading curtain (injected by page) -->
  <slot name="loader" />

  <!-- ── Header ── -->
  <header class="w-full bg-coco-ivory border-b border-coco-green/10 relative z-40">
    <!-- Top Utility Bar -->
    <div class="hidden md:flex justify-end gap-8 px-6 md:px-12 py-3 border-b border-coco-green/5 text-xs font-sans font-light tracking-[0.15em] uppercase text-coco-green/50">
      <a href="#" class="hover:text-coco-orange transition-colors">Portal</a>
      <a href="#" class="hover:text-coco-orange transition-colors">Support</a>
      <a href="#" class="hover:text-coco-orange transition-colors">Language</a>
      <a href="#" class="hover:text-coco-orange transition-colors">Search</a>
    </div>

    <!-- Main Navigation -->
    <nav class="px-6 md:px-12 py-6 flex justify-between items-center">
      <div class="flex items-center gap-10 lg:gap-16">
        <!-- Logo -->
        <a href="/" class="flex items-center group hover-trigger" data-cursor="HOME">
          <img
            src="/images/logo.png"
            alt="Coffee &amp; Cowrie"
            class="h-10 md:h-12 w-auto object-contain"
            style="mix-blend-mode: multiply;"
          />
        </a>

        <!-- Left Links -->
        <div class="hidden lg:flex gap-10">
          {navLeft.map(link => (
            <a
              href={link.href}
              class={`nav-link relative text-sm font-sans font-light tracking-[0.15em] uppercase transition-colors ${
                activeNav === link.key
                  ? 'text-coco-orange'
                  : 'text-coco-green/80 hover:text-coco-orange'
              }`}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Right Links & Avatar -->
      <div class="hidden lg:flex items-center gap-10">
        {navRight.map(link => (
          <a
            href={link.href}
            class={`nav-link relative text-sm font-sans font-light tracking-[0.15em] uppercase transition-colors ${
              activeNav === link.key
                ? 'text-coco-orange'
                : 'text-coco-green/80 hover:text-coco-orange'
            }`}
          >
            {link.label}
          </a>
        ))}
        <button class="w-10 h-10 rounded-full bg-coco-green flex items-center justify-center text-coco-ivory hover:bg-coco-orange transition-colors hover-trigger" data-cursor="LOGIN">
          <i data-lucide="user" class="w-4 h-4" stroke-width="1.5"></i>
        </button>
      </div>

      <!-- Mobile Menu Toggle -->
      <button id="mobile-menu-btn" class="lg:hidden group text-coco-green">
        <div class="space-y-1.5">
          <div class="w-6 h-px bg-current group-hover:w-4 transition-all duration-300 ml-auto"></div>
          <div class="w-6 h-px bg-current"></div>
          <div class="w-6 h-px bg-current group-hover:w-4 transition-all duration-300 ml-auto"></div>
        </div>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden px-6 pb-6 space-y-4 border-t border-coco-green/5">
      {[...navLeft, ...navRight].map(link => (
        <a href={link.href} class="block text-sm font-sans font-light tracking-[0.15em] uppercase text-coco-green/80 hover:text-coco-orange transition-colors py-2">
          {link.label}
        </a>
      ))}
    </div>
  </header>

  <!-- ── Page Content ── -->
  <slot />

  <!-- ── Footer ── -->
  <footer class="bg-coco-green text-coco-ivory pt-24 pb-12 px-6 md:px-12 relative overflow-hidden">
    <div class="absolute bottom-0 left-0 w-full select-none pointer-events-none opacity-[0.04]">
      <h2 class="text-[18vw] font-display font-semibold leading-none text-center tracking-tighter">COFFEE&amp;COWRIE</h2>
    </div>

    <div class="max-w-[1800px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 relative z-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="inline-block font-display font-medium text-3xl tracking-tighter mb-8">COFFEE&amp;COWRIE</a>
        <p class="font-serif text-xl italic max-w-sm mb-12 opacity-80 leading-relaxed">
          Valuing expertise, connecting talents.
        </p>
        <form class="flex gap-0 border-b border-coco-ivory/30 max-w-sm pb-2">
          <input type="email" placeholder="Request prospectus" class="bg-transparent w-full outline-none placeholder:text-coco-ivory/30 font-sans text-sm">
          <button type="button" class="text-xs font-semibold tracking-widest uppercase text-coco-orange hover:text-white transition-colors">Send</button>
        </form>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-coco-orange mb-6">Navigation</h4>
        <ul class="space-y-4 font-sans text-sm opacity-80">
          <li><a href="/" class="hover:text-coco-lime transition-colors">Home</a></li>
          <li><a href="/about" class="hover:text-coco-lime transition-colors">About</a></li>
          <li><a href="/journal" class="hover:text-coco-lime transition-colors">Journal</a></li>
          <li><a href="/contact" class="hover:text-coco-lime transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-coco-orange mb-6">Contact</h4>
        <ul class="space-y-4 font-sans text-sm opacity-80">
          <li>enquiries@coffeecowrie.edu</li>
          <li>+1 514 555 0199</li>
          <li>+33 1 99 00 12 34</li>
          <li class="mt-6">
            12 Heritage Lane,<br>
            Québec, CAN
          </li>
        </ul>
        <div class="flex gap-4 mt-8">
          <a href="#" class="text-coco-ivory/50 hover:text-coco-orange transition-colors"><i data-lucide="linkedin" class="w-5 h-5" stroke-width="1.5"></i></a>
          <a href="#" class="text-coco-ivory/50 hover:text-coco-orange transition-colors"><i data-lucide="twitter" class="w-5 h-5" stroke-width="1.5"></i></a>
          <a href="#" class="text-coco-ivory/50 hover:text-coco-orange transition-colors"><i data-lucide="instagram" class="w-5 h-5" stroke-width="1.5"></i></a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="max-w-[1800px] mx-auto mt-24 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between text-xs uppercase tracking-widest opacity-40 gap-4 relative z-10">
      <p>© 2025 COFFEE&amp;COWRIE Association. All rights reserved.</p>
      <div class="flex gap-8">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Accreditation</a>
      </div>
    </div>
  </footer>

  <!-- ── Global Scripts ── -->
  <script is:inline>
    // Initialize Lucide Icons
    lucide.createIcons();

    // ── Custom Cursor ──
    const cursorDot = document.querySelector('.cursor-dot');
    const cursorOutline = document.querySelector('.cursor-outline');

    if (cursorDot && cursorOutline) {
      window.addEventListener('mousemove', (e) => {
        cursorDot.style.left = `${e.clientX}px`;
        cursorDot.style.top  = `${e.clientY}px`;
        cursorOutline.animate(
          { left: `${e.clientX}px`, top: `${e.clientY}px` },
          { duration: 500, fill: 'forwards' }
        );
      });
    }

    function updateCursorListeners() {
      document.querySelectorAll('.hover-trigger').forEach(trigger => {
        trigger.addEventListener('mouseenter', () => {
          document.body.classList.add('hovering');
          if (trigger.getAttribute('data-cursor')) {
            cursorOutline.style.width  = '80px';
            cursorOutline.style.height = '80px';
            cursorOutline.style.mixBlendMode = 'difference';
          }
        });
        trigger.addEventListener('mouseleave', () => {
          document.body.classList.remove('hovering');
          cursorOutline.style.width  = '40px';
          cursorOutline.style.height = '40px';
          cursorOutline.style.mixBlendMode = 'normal';
        });
      });
    }
    updateCursorListeners();

    // ── Text Split & Reveal ──
    document.querySelectorAll('.reveal-text').forEach(el => {
      if (el.querySelectorAll('span.char').length > 0) return;
      const htmlContent = el.innerHTML.trim();
      el.innerHTML = '';
      const parts = htmlContent.split(/(<br\s*\/?>)/i);
      parts.forEach(part => {
        if (part.toLowerCase().includes('<br')) {
          el.appendChild(document.createElement('br'));
        } else if (part.trim() !== '') {
          part.trim().split(/\s+/).forEach(word => {
            const span = document.createElement('span');
            span.classList.add('inline-block', 'mr-3', 'overflow-hidden', 'align-top');
            span.innerHTML = `<span class="char inline-block translate-y-full transition-transform duration-700">${word}</span>`;
            el.appendChild(span);
          });
        }
      });
    });

    // ── Intersection Observer ──
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        if (el.classList.contains('reveal-text')) {
          el.classList.add('active');
          el.querySelectorAll('.char').forEach((char, i) => {
            setTimeout(() => {
              char.style.transform = 'translateY(0)';
              char.style.opacity = '1';
            }, i * 30);
          });
        }
        if (el.classList.contains('mask-reveal')) {
          el.classList.add('active');
        }
        revealObserver.unobserve(el);
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-text, .mask-reveal').forEach(el => revealObserver.observe(el));

    // Trigger visible elements immediately on load
    window.addEventListener('load', () => {
      setTimeout(() => {
        document.querySelectorAll('.reveal-text').forEach(el => {
          if (el.getBoundingClientRect().top < window.innerHeight) {
            el.classList.add('active');
            el.querySelectorAll('.char').forEach((char, i) => {
              setTimeout(() => {
                char.style.transform = 'translateY(0)';
                char.style.opacity = '1';
              }, i * 30);
            });
          }
        });
      }, 100);
    });

    // ── Mobile Menu ──
    const mobileBtn  = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (mobileBtn && mobileMenu) {
      mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
    }
  </script>

  <!-- Page-specific scripts injected here -->
  <slot name="scripts" />

</body>
</html>
